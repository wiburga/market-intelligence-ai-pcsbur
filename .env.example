# 🧠 Market Intelligence AI — Configuración
# ─────────────────────────────────────────────────────────

# ── API de Blackbox AI ────────────────────────────────────
# Obtén tu clave en https://cloud.blackbox.ai/
# La clave suele ser un token alfanumérico.
BLACKBOX_API_KEY=tu_api_key_aqui

# ── Configuración del modelo ──────────────────────────────
# Sugerido: blackboxai/blackbox-pro | blackbox-search
BLACKBOX_MODEL=blackboxai/blackbox-pro

# ── Logging ───────────────────────────────────────────────
# Opciones: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
